{
    "name": "codraw/log",
    "description": "Log related tool, mainly for monolog",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "draw",
        "log",
        "monolog"
    ],
    "authors": [
        {
            "name": "Martin Poirier Theoret",
            "email": "mpoiriert@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "monolog/monolog": "^3.5.0",
        "psr/log": "^3",
        "symfony/service-contracts": "^2.5 || ^3.0"
    },
    "require-dev": {
        "codraw/dependency-injection": "^0.39",
        "codraw/user-bundle": "^0.39",
        "phpunit/phpunit": "^11.3 || ^12.0",
        "symfony/event-dispatcher": "^6.4.0",
        "symfony/http-foundation": "^6.4.0",
        "symfony/http-kernel": "^6.4.0",
        "symfony/monolog-bridge": "^6.4.0",
        "symfony/security-core": "^6.4.0"
    },
    "suggest": {
        "codraw/dependency-injection": "To use the LogIntegration",
        "codraw/user-bundle": "To log the user id in the TokenProcessor",
        "symfony/dependency-injection": "To use the LoggerDecoratorPass and the LogIntegration",
        "symfony/event-dispatcher": "To use the SlowRequestLoggerListener",
        "symfony/http-foundation": "To use the RequestHeadersProcessor and the SlowRequestLoggerListener",
        "symfony/http-kernel": "To use the SlowRequestLoggerListener",
        "symfony/monolog-bridge": "To use the console_command processor of the LogIntegration",
        "symfony/security-core": "To use the TokenProcessor"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Draw\\Component\\Log\\": ""
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.39-dev"
        }
    },
    "replace": {
        "draw/log": "self.version"
    }
}
